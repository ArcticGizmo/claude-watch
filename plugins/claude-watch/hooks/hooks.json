{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/scripts/cleanup.ps1"
            ]
          }
        ]
      }
    ]
  }
}
